# Phase 0 — required to run the app at all. Create a Supabase project and
# copy these from Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser, never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 2 — Paystack (test mode keys to start; https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Phase 4 — Termii (SMS) and Zeptomail (email), both proven in justra-web.
TERMII_API_KEY=
TERMII_SENDER_ID=
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_ADDRESS=

# Phase 4 (later) — Meta WhatsApp Cloud API, added once Business
# verification + template approval clears. Not required for launch.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
